# LLM (generation, LLM-judge metrics, optimizer) — via litellm
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Opik (Comet-hosted). Leave OPIK_API_KEY/OPIK_WORKSPACE unset to run every command in DRY_RUN.
OPIK_API_KEY=your_opik_api_key_here
OPIK_WORKSPACE=your_workspace
OPIK_PROJECT_NAME=example-use-case

# Self-hosted / on-prem only; defaults to Opik Cloud if unset
# OPIK_URL_OVERRIDE=https://www.comet.com/opik/api

# Optional debug logging. Use a STATIC path — dotenv does not expand $(...) shell
# substitutions, and opik will crash on import trying to open a literal filename.
# OPIK_FILE_LOGGING_LEVEL=DEBUG
# OPIK_LOGGING_FILE=.tmp/opik-debug.log
