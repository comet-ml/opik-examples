# LLM (generation, LLM-judge metrics, optimizer) — via litellm
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Opik (Comet-hosted). Leave unset to run every command in DRY_RUN.
OPIK_API_KEY=your_opik_api_key_here
OPIK_WORKSPACE=your_workspace
OPIK_PROJECT_NAME=f1-radio-rag

# debugging
OPIK_FILE_LOGGING_LEVEL="DEBUG"
OPIK_LOGGING_FILE="opik-debug-$(date +%Y%m%d).log"

# Self-hosted / STSaaS only; defaults to Opik Cloud if unset
# OPIK_URL_OVERRIDE=https://www.comet.com/opik/api
